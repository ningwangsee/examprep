{
  "name": "examprep",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:import": "npx tsx prisma/seeds/import.ts",
    "db:translate": "npx tsx prisma/scripts/translate-questions.ts",
    "db:populate": "npx tsx prisma/scripts/populate-translations.ts",
    "db:shuffle": "npx tsx prisma/scripts/shuffle-options.ts",
    "validate:links": "npx tsx prisma/scripts/validate-links.ts",
    "validate:db": "npx tsx prisma/scripts/validate-db.ts",
    "validate": "npm run validate:db && npm run validate:links"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "16.2.6",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5"
  }
}
