generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model ExamCategory {
  id          Int         @id @default(autoincrement())
  name        String
  nameEn      String
  description String
  icon        String
  color       String      @default("#3B82F6")
  topics      ExamTopic[]
  createdAt   DateTime    @default(now())
}

model ExamTopic {
  id          Int          @id @default(autoincrement())
  name        String
  nameEn      String
  description String
  category    ExamCategory @relation(fields: [categoryId], references: [id])
  categoryId  Int
  questions   Question[]
  createdAt   DateTime     @default(now())
}

model Question {
  id          Int      @id @default(autoincrement())
  content     String
  explanation String
  topic       ExamTopic @relation(fields: [topicId], references: [id])
  topicId     Int
  options     Option[]
  difficulty  Int      @default(1)
  createdAt   DateTime @default(now())
}

model Option {
  id         Int      @id @default(autoincrement())
  content    String
  isCorrect  Boolean  @default(false)
  question   Question @relation(fields: [questionId], references: [id])
  questionId Int
}
